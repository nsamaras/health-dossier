# Auto-detect text files and normalise line endings to LF in the repository
* text=auto eol=lf

# Explicitly declare text files
*.ts        text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.xml       text eol=lf
*.gitignore text eol=lf

# Windows-specific scripts — keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary files — no line ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary
*.pdf       binary
*.zip       binary
*.gz        binary

